# =====================================================
# Variables de entorno — copiar a .env y rellenar
# NUNCA commitear el .env real al repositorio
# =====================================================

# --- Base de datos (producción) ---
DB_URL=jdbc:postgresql://postgres:5432/transferdb
DB_USERNAME=transfer_user
DB_PASSWORD=CAMBIAR_EN_PRODUCCION

# --- JWT ---
# Generar con: openssl rand -base64 64
JWT_SECRET=CAMBIAR_POR_CLAVE_SEGURA_DE_AL_MENOS_32_CARACTERES
JWT_EXPIRATION_MS=3600000
JWT_REFRESH_EXPIRATION_MS=604800000

# --- Spring ---
SPRING_PROFILES_ACTIVE=prod

# --- SonarQube ---
SONAR_TOKEN=PEGAR_TOKEN_GENERADO_EN_SONARQUBE
SONAR_HOST_URL=http://localhost:9000
